# ============================================================
# Data sources
# ============================================================

# SMC Engine (FastAPI) — local signal/positions/trades service
SMC_ENGINE_URL=http://localhost:8767

# Binance — set to "true" for demo-fapi, "false" for live
BINANCE_DEMO=true
BINANCE_DEMO_BASE=https://demo-api.binance.com

# ============================================================
# AI providers — both OpenAI-compatible
# ============================================================

# MiniMax-M3 (used for dashboard analysis & writing)
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3

# DeepSeek (used for pattern agent)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat